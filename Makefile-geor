SHELL := /bin/bash
IMAGE=georchestra/superset
REV=`git rev-parse --short HEAD`
DATE=`date +%Y%m%d-%H%M`

all: translations docker

frontend:
	source ~/.nvm/nvm.sh ;\
	nvm install lts/iron ;\
	nvm use lts/iron ;\

	# Install dependencies from `package-lock.json`
	npm --prefix superset-frontend install ;\
	# not sure this one is necessary:
	npm --prefix superset-frontend ci ;\
	npm --prefix superset-frontend run build ;\
	# Build i18n support
	npm --prefix superset-frontend run build-translation

translations: frontend
	npm --prefix superset-frontend run build-translation
	pybabel compile -d superset/translations


docker: docker-build docker-push

docker-build:
	docker build --target dev --build-arg BUILD_TRANSLATIONS="true" --cache-from apache/superset-cache:3.10-slim-bookworm -t ${IMAGE}:latest . ;\
	echo built ${IMAGE}:latest ;\
	docker tag  ${IMAGE}:latest ${IMAGE}:snapshot-${DATE}-${REV} ;\
	echo built ${IMAGE}:${DATE}-${REV}

docker-push:
	docker push ${IMAGE}:snapshot-${DATE}-${REV} ;\
	docker push ${IMAGE}:latest

